# ─── Tokko Broker ───
TOKKO_API_KEY=your_tokko_api_key_here

# ─── Meta / Facebook ───
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_long_lived_access_token
META_BUSINESS_ID=your_business_manager_id
# Leave empty to auto-create on first sync
META_CATALOG_ID=

# ─── Site ───
# Base URL for property detail pages (e.g. https://www.tuinmobiliaria.com/propiedad)
PROPERTY_BASE_URL=https://www.example.com/propiedad

# ─── Sync Options ───
# Filter: sale | rent | all
SYNC_OPERATION_TYPE=sale
